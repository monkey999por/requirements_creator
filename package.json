{
  "name": "requirements_creator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "各種データから連想方式でアプリケーション設計を行うためのツール",
  "scripts": {
    "collect": "tsx scripts/collect.ts",
    "extract": "bash scripts/extract.sh",
    "generate": "bash scripts/generate.sh",
    "generate:validate": "tsx scripts/validate-requirements.ts",
    "pipeline": "tsx scripts/pipeline.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.2.4",
    "yaml": "^2.8.2"
  }
}
