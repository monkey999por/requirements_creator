{
  "name": "requirements_creator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "各種データから連想方式でアプリケーション設計を行うためのツール",
  "scripts": {
    "collect": "tsx scripts/collect.ts",
    "extract": "tsx scripts/extract.ts",
    "generate": "tsx scripts/generate.ts",
    "pipeline": "tsx scripts/pipeline.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write ."
  },
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
